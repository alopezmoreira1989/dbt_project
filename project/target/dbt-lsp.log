select * from (
with customer as (

    select *
    from analytics.analytics_prod.stg_customer

)

, nation as (

    select *
    from analytics.analytics_prod.stg_nation

)

, region as (

    select *
    from analytics.analytics_prod.stg_region

)

, final as (

    select
        --primary key
